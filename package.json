{
  "name": "fad-checker",
  "version": "2.2.2",
  "description": "Scan ALL Maven, npm, Yarn, Composer, Python, C#/.NET, Go & Ruby dependencies — plus embedded JARs (fat-jars/war/ear) — in a source tree ONE SHOT without mvn/python/etc — CVE (EPSS/KEV-prioritised), EOL, obsolete, outdated & licenses, with SBOM/CSAF/SARIF/JSON exports, CI gating and fix recos",
  "keywords": [
    "sca",
    "software-composition-analysis",
    "dependency-scanner",
    "vulnerability-scanner",
    "security",
    "cve",
    "osv",
    "nvd",
    "epss",
    "kev",
    "cyclonedx",
    "sbom",
    "csaf",
    "vex",
    "sarif",
    "license-compliance",
    "eol",
    "end-of-life",
    "outdated",
    "deprecated",
    "audit",
    "devsecops",
    "appsec",
    "supply-chain",
    "offline",
    "air-gapped",
    "passi",
    "maven",
    "npm",
    "yarn",
    "pnpm",
    "composer",
    "pypi",
    "nuget",
    "go",
    "golang",
    "ruby",
    "rubygems",
    "retirejs",
    "polyglot",
    "cli"
  ],
  "license": "MIT",
  "repository": "https://github.com/n8tz/fad-checker",
  "homepage": "https://github.com/n8tz/fad-checker#readme",
  "bugs": "https://github.com/n8tz/fad-checker/issues",
  "author": "pp9Ping <pp9Ping@gmail.com>",
  "maintainers": [
    "pp9Ping <pp9Ping@gmail.com>"
  ],
  "contributors": [
    "pp9Ping <pp9Ping@gmail.com>"
  ],
  "bin": {
    "fad-checker": "fad-checker.js",
    "fad": "fad-checker.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:linux": "bun build fad-checker.js --compile --target=bun-linux-x64 --outfile=dist/fad-checker-linux",
    "build:win": "bun build fad-checker.js --compile --target=bun-windows-x64 --outfile=dist/fad-checker.exe",
    "build:macos": "bun build fad-checker.js --compile --target=bun-darwin-x64 --outfile=dist/fad-checker-macos",
    "build": "npm run build:linux && npm run build:win"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.1",
    "fflate": "^0.8.3",
    "js-yaml": "^4.1.1",
    "p-limit": "^3.1.0",
    "retire": "^5.4.2",
    "rimraf": "^6.0.1",
    "smol-toml": "^1.6.1",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
